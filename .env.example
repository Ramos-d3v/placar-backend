# Porta utilizada pelo servidor backend Express + Socket.io
PORT=3001

# Chave de segurança (API Key) exigida no header 'x-api-key' para validar envios de telemetria
# IMPORTANTE: Para ambiente de produção, gere uma chave criptograficamente segura, longa e aleatória.
API_KEY=GereUmaNovaChaveLongaEAleatoriaAquiParaProducao!

# Origens permitidas para conexões de segurança CORS (Express) e WebSockets (Socket.io)
# Separe múltiplos domínios por vírgula (sem espaços)
ALLOWED_ORIGINS=https://seu-placar-frontend.vercel.app,http://localhost:5173
